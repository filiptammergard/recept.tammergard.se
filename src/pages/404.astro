---
import BaseHead from "@components/BaseHead.astro"
import Header from "@components/Header.astro"

const title = "Sidan hittades inte"
const description = "Receptet du letar efter finns inte här."
const permalink = Astro.url.href
---

<html lang="sv">
	<head>
		<BaseHead title={title} description={description} permalink={permalink} />
		<meta name="robots" content="noindex" />
	</head>

	<body>
		<Header />
		<main class="wrapper">
			<section class="intro">
				<h1>{title}</h1>
				<p>{description}</p>
				<p><a href="/">Tillbaka till receptsamlingen</a></p>
			</section>
		</main>

		<style>
			.intro {
				margin-top: 6rem;
			}
		</style>
	</body>
</html>
