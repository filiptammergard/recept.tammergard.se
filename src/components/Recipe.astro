---
export interface Props {
	description: string
	minutes: number
	source: string | undefined
	title: string
}

const { description, minutes, source, title } = Astro.props
---

<article class="recipe">
	<header class="recipe-header">
		<a href="/" class="back-link no-print">
			<span aria-hidden="true">←</span> Alla recept
		</a>
		<h1 class="recipe-title">{title}</h1>
		<p class="recipe-description">{description}</p>
		<div class="recipe-meta">
			<span class="badge">
				<span aria-hidden="true">⏱</span>&nbsp;{minutes} min
			</span>
			{
				source && (
					<a class="source-link" href={source}>
						Inspirationskälla ↗
					</a>
				)
			}
		</div>
	</header>
	<div class="recipe-body">
		<slot />
	</div>
</article>

<style>
	.recipe {
		max-width: 44rem;
		margin-inline: auto;
		margin-block: 2rem 6rem;
	}

	.recipe-header {
		padding-bottom: 2rem;
		margin-bottom: 2rem;
		border-bottom: 1px solid var(--theme-divider);
	}

	.back-link {
		display: inline-block;
		margin-bottom: 1.5rem;
		font-size: 0.9rem;
		color: var(--theme-text-light);
		text-decoration: none;
	}

	.back-link:hover {
		color: var(--theme-accent);
	}

	.recipe-title {
		margin: 0;
		font-size: clamp(2.25rem, 5vw, 3rem);
	}

	.recipe-description {
		margin-top: 1rem;
		font-size: 1.1rem;
		line-height: 1.6;
		color: var(--theme-text-light);
	}

	.recipe-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1.25rem;
		align-items: center;
		margin-top: 1.5rem;
	}

	.badge {
		display: inline-flex;
		align-items: center;
		padding: 0.4rem 0.85rem;
		background: var(--theme-accent-soft);
		color: var(--theme-accent);
		font-size: 0.9rem;
		font-weight: 600;
		border-radius: 999px;
	}

	.source-link {
		font-size: 0.9rem;
		color: var(--theme-text-light);
		text-decoration: underline;
		text-decoration-thickness: 1px;
	}

	.source-link:hover {
		color: var(--theme-accent);
	}

	.recipe-body :global(h2) {
		font-size: 1.5rem;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
	}

	.recipe-body :global(ul),
	.recipe-body :global(ol) {
		padding-left: 1.25rem;
		margin-bottom: 1.25rem;
	}

	.recipe-body :global(li) {
		margin-bottom: 0.35rem;
		color: var(--theme-text);
	}

	.recipe-body :global(p) {
		margin-bottom: 1.25rem;
		color: var(--theme-text);
	}
</style>
