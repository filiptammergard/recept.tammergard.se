---
export interface Props {
	category: string
	description: string
	minutes: number
	source: string | undefined
	title: string
}

const categoryEmoji: Record<string, string> = {
	Huvudrätt: "🥘",
	Efterrätt: "🍰",
	Bröd: "🥖",
	Frukost: "🥐",
	Dryck: "🥤",
}

const { category, description, minutes, source, title } = Astro.props
const emoji = categoryEmoji[category] ?? "🍽"
---

<article class="recipe">
	<header class="recipe-header">
		<a href="/" class="back-link no-print">
			<span aria-hidden="true">←</span> Alla recept
		</a>
		<h1 class="recipe-title">{title}</h1>
		<p class="recipe-description">{description}</p>
		<div class="recipe-meta">
			<span class="info-pill">
				<span aria-hidden="true">⏱</span>&nbsp;{minutes} min
			</span>
			<a
				class="chip chip-link"
				href={`/?kategori=${encodeURIComponent(category.toLowerCase())}`}
			>
				<span class="chip-emoji" aria-hidden="true">{emoji}</span>
				{category}
			</a>
		</div>
		{
			source && (
				<p class="source-row">
					<a class="source-link" href={source}>
						Inspirationskälla ↗
					</a>
				</p>
			)
		}
	</header>
	<div class="recipe-body">
		<slot />
	</div>
</article>

<style>
	.recipe {
		max-width: 44rem;
		margin-inline: auto;
		margin-block: 2rem 6rem;
	}

	.recipe-header {
		padding-bottom: 2rem;
		margin-bottom: 2rem;
		border-bottom: 1px solid var(--theme-divider);
	}

	.back-link {
		display: inline-block;
		margin-bottom: 1.5rem;
		font-size: 0.9rem;
		color: var(--theme-text-light);
		text-decoration: none;
	}

	.back-link:hover {
		color: var(--theme-accent);
	}

	.recipe-title {
		margin: 0;
		font-size: clamp(2.25rem, 5vw, 3rem);
	}

	.recipe-description {
		margin-top: 1rem;
		font-size: 1.1rem;
		line-height: 1.6;
		color: var(--theme-text-light);
	}

	.recipe-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
		margin-top: 1.5rem;
	}

	.info-pill {
		display: inline-flex;
		align-items: center;
		padding: 0.45rem 0.9rem;
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--theme-accent);
		background: var(--theme-accent-soft);
		border-radius: 999px;
		white-space: nowrap;
	}

	.chip {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.45rem 0.9rem;
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--theme-text);
		background: var(--theme-surface);
		border: 1px solid var(--theme-divider);
		border-radius: 999px;
		white-space: nowrap;
	}

	.chip-emoji {
		font-size: 1rem;
		line-height: 1;
	}

	.chip-link {
		text-decoration: none;
		transition:
			background 0.15s ease,
			border-color 0.15s ease,
			color 0.15s ease;
	}

	.chip-link:hover,
	.chip-link:focus-visible {
		background: var(--theme-accent);
		color: var(--theme-bg);
		border-color: var(--theme-accent);
		text-decoration: none;
	}

	.source-row {
		margin-top: 1rem;
	}

	.source-link {
		font-size: 0.9rem;
		color: var(--theme-text-light);
		text-decoration: underline;
		text-decoration-thickness: 1px;
	}

	.source-link:hover {
		color: var(--theme-accent);
	}

	.recipe-body :global(h2) {
		font-size: 1.5rem;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
	}

	.recipe-body :global(ul),
	.recipe-body :global(ol) {
		padding-left: 1.25rem;
		margin-bottom: 1.25rem;
	}

	.recipe-body :global(li) {
		margin-bottom: 0.35rem;
		color: var(--theme-text);
	}

	.recipe-body :global(p) {
		margin-bottom: 1.25rem;
		color: var(--theme-text);
	}
</style>
