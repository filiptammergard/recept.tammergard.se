---
import { type CollectionEntry, getCollection } from "astro:content"

type RecipeEntry = CollectionEntry<"recipes">

const recipes = await getCollection("recipes")
const slugs = recipes.map((r: RecipeEntry) => r.id)
---

<header class="site-header no-print">
	<div class="wrapper header-inner">
		<a href="/" class="brand">
			<span class="brand-emoji" aria-hidden="true">😋</span>
			<span>Tammergård</span>
		</a>
		<button
			type="button"
			class="random-btn"
			data-random-recipe
			aria-label="Slumpa fram ett recept"
		>
			<span aria-hidden="true">🎲</span>
			<span class="random-label">Slumpa recept</span>
		</button>
	</div>
</header>

<script is:inline define:vars={{ slugs }}>
	const btn = document.querySelector("[data-random-recipe]")
	if (btn && Array.isArray(slugs) && slugs.length > 0) {
		btn.addEventListener("click", () => {
			const next = slugs[Math.floor(Math.random() * slugs.length)]
			window.location.href = `/${next}`
		})
	}
</script>

<style>
	.site-header {
		border-bottom: 1px solid var(--theme-divider);
		background: var(--theme-bg);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding-block: 1rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-display);
		font-size: 1.5rem;
		font-weight: 600;
		color: var(--theme-text);
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.brand-emoji {
		font-size: 1.35rem;
		line-height: 1;
		transition: transform 0.2s ease;
	}

	.brand:hover {
		color: var(--theme-accent);
		text-decoration: none;
	}

	.brand:hover .brand-emoji {
		transform: rotate(-8deg) scale(1.1);
	}

	.random-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		font: inherit;
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--theme-text);
		background: var(--theme-surface);
		border: 1px solid var(--theme-divider);
		border-radius: 999px;
		cursor: pointer;
		transition:
			background 0.15s ease,
			border-color 0.15s ease,
			color 0.15s ease,
			transform 0.15s ease;
	}

	.random-btn:hover {
		background: var(--theme-accent);
		color: var(--theme-bg);
		border-color: var(--theme-accent);
	}

	.random-btn:active {
		transform: scale(0.96);
	}

	.random-btn:focus-visible {
		outline: 2px solid var(--theme-accent);
		outline-offset: 2px;
	}

	@media (max-width: 28rem) {
		.random-label {
			display: none;
		}

		.random-btn {
			padding: 0.5rem 0.75rem;
			font-size: 1.1rem;
		}
	}
</style>
